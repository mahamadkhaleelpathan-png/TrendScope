# ============================================================================
# TrendScope Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================================================================
# API Keys
# ============================================================================

# GNews API Key (optional) - Get from https://gnews.io/
# Used as an additional news source alongside RSS feeds.
GNEWS_API_KEY=

# NewsData API Key (optional) - Get from https://newsdata.io/
# Used as an additional news source alongside RSS feeds.
NEWSDATA_API_KEY=

# OpenRouter API Key (optional) - Get from https://openrouter.ai/
# Used for AI-powered features (translation, summarization).
OPENROUTER_API_KEY=

# ============================================================================
# Backend Security (bharat-bhasha-ai)
# ============================================================================

# Secret key for Flask session signing and encryption.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Secret key for signing JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ============================================================================
# Android Keystore (Release Signing)
# ============================================================================

# Path to the release keystore file (relative to app/ directory)
KEYSTORE_PATH=release.keystore

# Keystore store password
KEYSTORE_STORE_PASSWORD=

# Keystore key alias
KEYSTORE_KEY_ALIAS=trendscope

# Keystore key password
KEYSTORE_KEY_PASSWORD=

# ============================================================================
# Output
# ============================================================================

# Directory to store generated data files
OUTPUT_DIR=data
